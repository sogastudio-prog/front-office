+/*
+SoloDrive Front CSS — Premium Marketing System
+Purpose: move the new home/start inline styles into the repo-owned CSS layer.
+
+Scope:
+- Home page: .sd-home-premium
+- Start page: .sd-start-premium
+- Shared marketing primitives: .sd-premium-*
+
+This file intentionally loads last so it can override older clean-slate page rules
+without relying on Gutenberg inline styles.
+*/
+
+:root {
+  --sd-premium-navy: #121b36;
+  --sd-premium-navy-2: #162447;
+  --sd-premium-ink: #121b36;
+  --sd-premium-muted: #5e687d;
+  --sd-premium-faint: #8a94aa;
+  --sd-premium-cream: #f3f1eb;
+  --sd-premium-cream-2: #f5f3ec;
+  --sd-premium-dark: #101827;
+  --sd-premium-line: rgba(18, 27, 54, 0.09);
+  --sd-premium-shadow: 0 22px 56px rgba(18, 27, 54, 0.08);
+  --sd-premium-shadow-strong: 0 28px 70px rgba(18, 27, 54, 0.18);
+  --sd-premium-hero-image: url("https://solodrive.pro/wp-content/uploads/2026/05/solodrive-hero.png");
+}
+
+body:has(.sd-home-premium),
+body:has(.sd-start-premium) {
+  background: var(--sd-premium-cream);
+}
+
+body:has(.sd-home-premium) .site-content,
+body:has(.sd-start-premium) .site-content,
+body:has(.sd-home-premium) .ast-container,
+body:has(.sd-start-premium) .ast-container,
+body:has(.sd-home-premium) .entry-content,
+body:has(.sd-start-premium) .entry-content {
+  max-width: none !important;
+  width: 100% !important;
+  padding: 0 !important;
+  margin: 0 !important;
+}
+
+body:has(.sd-home-premium) .entry-title,
+body:has(.sd-start-premium) .entry-title,
+body:has(.sd-home-premium) header.entry-header,
+body:has(.sd-start-premium) header.entry-header {
+  display: none !important;
+}
+
+.sd-home-premium,
+.sd-start-premium {
+  background: var(--sd-premium-cream);
+  color: var(--sd-premium-ink);
+  overflow: hidden;
+}
+
+.sd-premium-container {
+  width: min(100%, 1180px);
+  margin-inline: auto;
+  padding-inline: 20px;
+}
+
+.sd-premium-eyebrow {
+  margin: 0 0 14px !important;
+  font-size: 0.82rem !important;
+  line-height: 1.2 !important;
+  font-weight: 850 !important;
+  letter-spacing: 0.14em !important;
+  text-transform: uppercase !important;
+  color: var(--sd-premium-faint) !important;
+}
+
+.sd-premium-title,
+.sd-premium-section-title {
+  margin: 0 !important;
+  color: var(--sd-premium-ink) !important;
+  font-weight: 850 !important;
+  letter-spacing: -0.055em !important;
+}
+
+.sd-premium-title {
+  font-size: clamp(3rem, 6.4vw, 5.75rem) !important;
+  line-height: 0.96 !important;
+}
+
+.sd-premium-section-title {
+  max-width: 900px;
+  font-size: clamp(2.2rem, 4.8vw, 4.4rem) !important;
+  line-height: 0.98 !important;
+}
+
+.sd-premium-lede,
+.sd-premium-intro {
+  max-width: 760px;
+  margin: 18px 0 0 !important;
+  font-size: clamp(1.08rem, 1.8vw, 1.28rem) !important;
+  line-height: 1.58 !important;
+  color: var(--sd-premium-muted) !important;
+}
+
+.sd-premium-btn,
+.sd-premium-link-btn,
+.sd-home-premium .wp-block-button__link,
+.sd-start-premium .wp-block-button__link {
+  display: inline-flex !important;
+  align-items: center !important;
+  justify-content: center !important;
+  gap: 10px !important;
+  min-height: 54px !important;
+  padding: 16px 24px !important;
+  border-radius: 999px !important;
+  font-size: 1rem !important;
+  font-weight: 850 !important;
+  line-height: 1 !important;
+  text-decoration: none !important;
+  border: 0 !important;
+}
+
+.sd-premium-btn--light {
+  background: #ffffff !important;
+  color: #111111 !important;
+  box-shadow: 0 18px 46px rgba(0, 0, 0, 0.32) !important;
+}
+
+.sd-premium-btn--dark,
+.sd-start-premium input[type="submit"],
+.sd-start-premium button[type="submit"] {
+  background: var(--sd-premium-navy) !important;
+  color: #ffffff !important;
+}
+
+.sd-premium-text-link {
+  color: inherit !important;
+  font-weight: 800 !important;
+  text-decoration: underline !important;
+  text-underline-offset: 4px !important;
+}
+
+/* Hero */
+.sd-premium-hero {
+  position: relative !important;
+  min-height: 92vh !important;
+  display: flex !important;
+  align-items: center !important;
+  overflow: hidden !important;
+  color: #ffffff !important;
+  background-image:
+    linear-gradient(90deg, rgba(0,0,0,.9) 0%, rgba(0,0,0,.78) 34%, rgba(0,0,0,.42) 62%, rgba(0,0,0,.18) 100%),
+    var(--sd-premium-hero-image) !important;
+  background-size: cover !important;
+  background-position: center right !important;
