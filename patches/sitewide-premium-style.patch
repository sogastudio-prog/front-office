+.sd-premium-final-cta__actions { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; margin-top: 28px; }
+
+/* Start page */
+.sd-start-main { background: var(--sd-premium-cream); padding: 34px 0 96px; }
+.sd-start-layout { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(320px, .75fr); gap: 28px; align-items: start; }
+.sd-start-layout__main { display: grid; gap: 28px; }
+.sd-start-card { background: #ffffff; border: 1px solid var(--sd-premium-line); border-radius: 30px; box-shadow: var(--sd-premium-shadow); padding: clamp(28px, 4vw, 42px); }
+.sd-start-card h2 { margin-top: 0 !important; font-size: clamp(2.2rem, 4vw, 3.7rem) !important; line-height: 1 !important; letter-spacing: -.05em !important; color: var(--sd-premium-ink) !important; }
+.sd-start-side-card { position: sticky; top: 36px; padding: 34px; border-radius: 30px; background: linear-gradient(135deg, var(--sd-premium-dark), var(--sd-premium-navy-2)); color: #fff; box-shadow: var(--sd-premium-shadow-strong); }
+.sd-start-side-card h2 { margin: 0 0 28px !important; font-size: clamp(2rem, 3vw, 3rem) !important; line-height: 1 !important; letter-spacing: -.045em !important; color: #fff !important; }
+.sd-start-side-card ol { display: grid; gap: 16px; margin: 0; padding: 0; list-style: none; counter-reset: startSteps; }
+.sd-start-side-card li { counter-increment: startSteps; position: relative; padding: 18px 18px 18px 58px; border-radius: 20px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: rgba(255,255,255,.68); }
+.sd-start-side-card li:before { content: counter(startSteps, decimal-leading-zero); position: absolute; left: 18px; top: 19px; font-size: .75rem; font-weight: 850; color: rgba(255,255,255,.45); }
+.sd-start-side-card strong { display: block; margin-bottom: 6px; color: #fff; }
+.sd-start-side-card span { display: block; color: rgba(255,255,255,.68); line-height: 1.45; }
+.sd-start-premium .wpcf7 form p { margin-bottom: 22px; }
+.sd-start-premium .wpcf7 label { display: block; color: var(--sd-premium-ink); font-weight: 750; margin-bottom: 8px; }
+.sd-start-premium input:not([type="submit"]):not([type="checkbox"]),
+.sd-start-premium textarea,
+.sd-start-premium select { width: 100%; min-height: 48px; border: 1px solid rgba(18,27,54,.12); border-radius: 10px; padding: 10px 12px; background: #ffffff; }
+.sd-start-premium .sdfo-package-grid,
+.sd-start-premium .sd-package-grid { gap: 18px; }
+
+@media (max-width: 1024px) {
+  .sd-product-proof-grid,
+  .sd-premium-proof-grid { grid-template-columns: 1fr; }
+  .sd-driver-outcome__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .sd-driver-benefit { min-height: 260px; }
+  .sd-product-card__media { min-height: auto; }
+  .sd-product-card__media img { height: auto; max-height: none; object-fit: contain; }
+}
+
+@media (max-width: 900px) {
+  .sd-start-layout { grid-template-columns: 1fr; }
+  .sd-start-side-card { position: static; }
+}
+
+@media (max-width: 767px) {
+  .sd-premium-container { padding-inline: 14px; }
+  .sd-premium-hero { min-height: auto !important; align-items: flex-end !important; background-image: linear-gradient(180deg, rgba(0,0,0,.28) 0%, rgba(0,0,0,.58) 38%, rgba(0,0,0,.92) 100%), var(--sd-premium-hero-image) !important; background-position: 68% center !important; }
+  .sd-premium-hero__inner { padding: 58vh 20px 42px !important; }
+  .sd-premium-title { font-size: clamp(2.45rem, 13vw, 3.65rem) !important; line-height: .98 !important; letter-spacing: -.055em !important; }
+  .sd-premium-hero__lede { font-size: 1.05rem !important; line-height: 1.42 !important; }
+  .sd-premium-hero__actions { display: grid; gap: 14px; }
+  .sd-premium-btn, .sd-premium-link-btn, .sd-home-premium .wp-block-button__link, .sd-start-premium .wp-block-button__link { width: 100%; min-height: 58px !important; }
+  .sd-premium-section { padding: 56px 0; }
+  .sd-premium-section-title { font-size: clamp(2rem, 10vw, 3rem) !important; line-height: .98 !important; }
+  .sd-driver-outcome { padding: 64px 0 !important; }
+  .sd-driver-outcome__grid { grid-template-columns: 1fr; gap: 14px; }
+  .sd-driver-benefit { min-height: auto; padding: 22px; border-radius: 22px; }
+  .sd-driver-benefit__num { margin-bottom: 34px; }
+  .sd-premium-final-cta { padding: 56px 0 74px; }
+  .sd-premium-final-cta__panel { padding: 34px 22px; border-radius: 24px; }
+  .sd-premium-final-cta__actions { flex-direction: column; align-items: stretch; }
+  .sd-start-main { padding: 18px 0 72px; }
+  .sd-start-card, .sd-start-side-card { padding: 24px; border-radius: 24px; }
+}
