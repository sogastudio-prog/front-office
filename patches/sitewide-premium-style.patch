+  color: rgba(255,255,255,.9) !important;
+}
+.sd-premium-hero__promise {
+  margin: 22px 0 0 !important;
+  font-size: clamp(1.05rem, 1.6vw, 1.22rem) !important;
+  line-height: 1.4 !important;
+  font-weight: 800 !important;
+  color: #ffffff !important;
+}
+.sd-premium-hero__actions { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; margin-top: 34px; }
+.sd-premium-hero__secondary { color: rgba(255,255,255,.86) !important; border-bottom: 1px solid rgba(255,255,255,.44); padding-bottom: 3px; text-decoration: none !important; }
+.sd-premium-trust { display: flex; flex-wrap: wrap; gap: 12px; max-width: 700px; margin-top: 38px; }
+.sd-premium-trust span { display: inline-flex; align-items: center; min-height: 34px; padding: 7px 12px; border-radius: 999px; background: rgba(255,255,255,.105); border: 1px solid rgba(255,255,255,.16); color: rgba(255,255,255,.86); font-size: .9rem; font-weight: 700; }
+
+/* Light proof sections */
+.sd-premium-section {
+  padding: 80px 0;
+  background: var(--sd-premium-cream);
+}
+.sd-premium-section--soft { background: var(--sd-premium-cream-2); }
+.sd-premium-proof-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 36px; }
+.sd-premium-card { background: #ffffff; border: 1px solid var(--sd-premium-line); border-radius: 24px; box-shadow: var(--sd-premium-shadow); padding: 24px; }
+.sd-premium-card h3 { margin: 0 0 10px !important; font-size: 1.18rem !important; line-height: 1.15 !important; color: var(--sd-premium-ink) !important; font-weight: 850 !important; }
+.sd-premium-card p { margin: 0 !important; line-height: 1.55 !important; color: var(--sd-premium-muted) !important; }
+
+/* Product proof cards */
+.sd-product-proof-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; margin-top: 40px; }
+.sd-product-card { display: flex; flex-direction: column; background: #ffffff; border: 1px solid var(--sd-premium-line); border-radius: 28px; overflow: hidden; box-shadow: 0 18px 42px rgba(18,27,54,.06); }
+.sd-product-card__media { background: #e9edf5; padding: 16px; min-height: 420px; }
+.sd-product-card__media img { display: block; width: 100%; height: 520px; object-fit: cover; object-position: top center; border-radius: 22px; border: 1px solid rgba(18,27,54,.08); background: #eef1f6; }
+.sd-product-card__placeholder { min-height: 500px; display: flex; align-items: flex-start; padding: 14px; border-radius: 22px; border: 1px solid rgba(18,27,54,.08); background: #eef1f6; color: #121b36; font-size: .92rem; line-height: 1.35; }
+.sd-product-card__body { padding: 22px 22px 24px; }
+.sd-product-card__body h3 { margin: 0 0 10px !important; font-size: 1.35rem !important; line-height: 1.15 !important; font-weight: 850 !important; color: var(--sd-premium-ink) !important; }
+.sd-product-card__body p { margin: 0 !important; font-size: 1rem !important; line-height: 1.55 !important; color: var(--sd-premium-muted) !important; }
+
+/* Dark outcome */
+.sd-driver-outcome { background: var(--sd-premium-dark) !important; color: #ffffff !important; padding: 88px 0 !important; }
+.sd-driver-outcome .sd-premium-eyebrow { color: rgba(255,255,255,.58) !important; }
