+}
+
+.sd-premium-hero__inner {
+  width: 100% !important;
+  max-width: 1180px !important;
+  margin: 0 auto !important;
+  padding: 96px 28px !important;
+  position: relative !important;
+  z-index: 2 !important;
+}
+
+.sd-premium-hero__content { max-width: 690px; }
+.sd-premium-hero .sd-premium-eyebrow { color: rgba(255,255,255,.74) !important; }
+.sd-premium-hero .sd-premium-title { color: #ffffff !important; text-shadow: 0 18px 48px rgba(0,0,0,.48) !important; }
+.sd-premium-hero__lede {
+  max-width: 650px;
+  margin: 24px 0 0 !important;
+  font-size: clamp(1.18rem, 2vw, 1.55rem) !important;
+  line-height: 1.36 !important;
